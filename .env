# Arma 3 Server Manager - base environment.
# This file is committed as a safe template. Replace placeholder values on your server.

# SteamCMD account
# Leave STEAM_PASS empty if you want to use the interactive SteamCMD Login window.
STEAM_USER=
STEAM_PASS=

# Web management panel
WEB_PORT=8080
WEB_BIND_IP=127.0.0.1
WEB_USERNAME=admin
WEB_PASSWORD=change_this_panel_password
SESSION_SECRET=change_this_to_a_long_random_secret

# Same-origin nginx setup; leave blank unless splitting frontend/backend manually.
FRONTEND_ORIGIN=

# Panel callback URL. Keep localhost if the panel is private on the host.
BASE_URL=http://127.0.0.1:8080

# Public game address shown in the dashboard. Use your server public IPv4 or DNS name.
PUBLIC_JOIN_HOST=YOUR_PUBLIC_IP_OR_DOMAIN

# Optional comma-separated Steam64 IDs allowed to link/login with Steam.
STEAM_OWNER_IDS=

# Arma 3 server ports. Forward UDP ports 2302-2305 from your router/firewall.
SERVER_PORT=2302
SERVER_QUERY_PORT=2303
BATTLEYE_PORT=2304
VON_PORT=2305

# Default Arma 3 server settings
SERVER_NAME=Arma 3 Server
SERVER_PASSWORD=
SERVER_PASSWORD_ADMIN=change_this_admin_password
SERVER_MAX_PLAYERS=40
AUTO_START_SERVER=false

# Optional comma-separated Creator DLC Steam app IDs for the Download DLCs action.
CREATOR_DLC_APP_IDS=

# Runtime
MOCK_STEAMCMD=false
TZ=America/Mexico_City
SERVER_MEM_LIMIT=14g

# Keep these blank unless you intentionally use a host-network overlay.
#API_NETWORK_MODE=host
#API_PORT=8081
#ARMA3_API_BACKEND=10.89.0.1:8081
