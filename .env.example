# Arma 3 Server Manager - Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit .env to version control.

# SteamCMD account
# Required to install/update the Arma 3 dedicated server and download Workshop mods.
# You can leave STEAM_PASS empty and use the interactive SteamCMD Login window.
STEAM_USER=your_steam_username
STEAM_PASS=

# Web management panel
WEB_PORT=8080
WEB_USERNAME=admin
WEB_PASSWORD=changeme123
SESSION_SECRET=replace_with_random_secret

# Used only if frontend/backend run on different origins during development.
# Leave blank with podman-compose.yml because nginx proxies /api to Kestrel.
FRONTEND_ORIGIN=

# Steam OpenID link/login
# BASE_URL is needed for public deployments so Steam can return to your panel.
# Example: http://123.45.67.89:8080
BASE_URL=

# Optional comma-separated Steam64 IDs allowed to link/login with Steam.
# Leave blank until you know which Steam IDs should be allowed.
STEAM_OWNER_IDS=

# Arma 3 server ports
SERVER_PORT=2302
SERVER_QUERY_PORT=2303
BATTLEYE_PORT=2304
VON_PORT=2305

# Default Arma 3 server settings
SERVER_NAME=My Arma 3 Server
SERVER_PASSWORD=
SERVER_PASSWORD_ADMIN=adminpass
SERVER_MAX_PLAYERS=32
AUTO_START_SERVER=false

# Local testing only
MOCK_STEAMCMD=false

# Timezone
TZ=UTC

# Podman resource limits
SERVER_MEM_LIMIT=14g
