# ─── Arma 3 Server Manager — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Steam Credentials ─────────────────────────────────────────────────────────
#
#  What requires a Steam account?
#  ┌─────────────────────────────────────────┬────────────────────────────────┐
#  │ Action                                  │ Requires Steam login?          │
#  ├─────────────────────────────────────────┼────────────────────────────────┤
#  │ Install / update Arma 3 server binary   │ YES — must own Arma 3 on Steam │
#  │ Download Steam Workshop mods            │ YES — account + Arma 3 owned   │
#  └─────────────────────────────────────────┴────────────────────────────────┘
#
#  NOTE: AppID 233780 (Arma 3 Server) requires owning Arma 3 on the account.
#  Anonymous login will fail with "No subscription".
#  If your server is already installed (hosted server), you only need
#  credentials for mod downloads.
STEAM_USER=your_steam_username
STEAM_PASS=

# ── Web Management Panel ──────────────────────────────────────────────────────
WEB_PORT=8080
WEB_USERNAME=admin
WEB_PASSWORD=changeme123
# Generate a strong random value for this (e.g. `openssl rand -hex 32`)
SESSION_SECRET=replace_with_random_secret
# Used when frontend and backend run on different origins during development.
# Leave blank when using podman-compose.yml, because nginx proxies /api to Kestrel.
FRONTEND_ORIGIN=

# ── Steam OpenID Login ("Login with Steam" button) ───────────────────────────
# The public URL of this panel (used for Steam's OpenID callback).
# For local testing leave blank — it auto-detects from the request.
# For production set this to e.g.: http://123.45.67.89:8080
BASE_URL=
# Comma-separated Steam64 IDs allowed to log in via Steam OpenID.
# Leave blank to allow ANY Steam account (not recommended for public servers).
# Your Steam64 ID can be found at: https://steamidfinder.com
STEAM_OWNER_IDS=76561198074208173

# ── Arma 3 Server ─────────────────────────────────────────────────────────────
SERVER_PORT=2302
SERVER_QUERY_PORT=2303
BATTLEYE_PORT=2304
VON_PORT=2305

SERVER_NAME=My Arma 3 Server
SERVER_PASSWORD=
SERVER_PASSWORD_ADMIN=adminpass
SERVER_MAX_PLAYERS=32
AUTO_START_SERVER=false

# Local testing only: fake SteamCMD login / Steam Guard flow
MOCK_STEAMCMD=false

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Resource Limits (Docker deploy) ──────────────────────────────────────────
CPU_LIMIT=4
MEM_LIMIT=8G
# Podman compose memory cap for the API/game-server container.
SERVER_MEM_LIMIT=14g
