---
import BaseLayout from '../layouts/BaseLayout.astro';
import RuntimeStatus from '../components/RuntimeStatus.vue';
---

<BaseLayout title="Brigada 46 Server Manager">
<!-- ════ LOGIN OVERLAY ══════════════════════════════════════════════════════ -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">
      <img src="/assets/brigada_46.png" alt="Brigada 46" />
    </div>
    <h4 class="login-title">Brigada 46 Manager</h4>
    <p class="login-sub">Sign in to continue</p>
    <div id="login-error" class="alert alert-danger d-none"></div>
    <form id="login-form">
      <div class="mb-3">
        <input type="text" id="login-user" class="form-control" placeholder="Username" autocomplete="username" required />
      </div>
      <div class="mb-3">
        <input type="password" id="login-pass" class="form-control" placeholder="Password" autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="fa fa-sign-in-alt me-2"></i>Sign In
      </button>
    </form>
  </div>
</div>

<!-- ════ MAIN APP ══════════════════════════════════════════════════════════ -->
<div id="app" class="d-none">

  <!-- Sidebar -->
  <nav id="sidebar">
    <div class="sidebar-brand">
      <img src="/assets/brigada_46.png" alt="Brigada 46" />
      <span>Brigada 46</span>
    </div>
    <ul class="sidebar-nav">
      <li><a href="#dashboard" class="nav-link active" data-view="dashboard"><i class="fa fa-gauge-high"></i><span>Dashboard</span></a></li>
      <li><a href="#mods" class="nav-link" data-view="mods"><i class="fa fa-puzzle-piece"></i><span>Mods</span></a></li>
      <li><a href="#files" class="nav-link" data-view="files"><i class="fa fa-folder-open"></i><span>File Manager</span></a></li>
      <li><a href="#config" class="nav-link" data-view="config"><i class="fa fa-sliders"></i><span>Config Editor</span></a></li>
      <li><a href="#logs" class="nav-link" data-view="logs"><i class="fa fa-terminal"></i><span>Server Logs</span></a></li>
      <li><a href="#rcon" class="nav-link" data-view="rcon"><i class="fa fa-satellite-dish"></i><span>RCON Console</span></a></li>
      <li><a href="#settings" class="nav-link" data-view="settings"><i class="fa fa-gear"></i><span>Settings</span></a></li>
    </ul>
    <div class="sidebar-footer">
      <button id="btn-logout" class="btn btn-sm btn-outline-secondary w-100">
        <i class="fa fa-sign-out-alt me-1"></i>Logout
      </button>
    </div>
  </nav>

  <!-- Main -->
  <div id="main">
    <!-- Top bar -->
    <header id="topbar">
      <button id="sidebar-toggle" class="btn btn-icon me-3">
        <i class="fa fa-bars"></i>
      </button>
      <div class="topbar-title" id="page-title">Dashboard</div>
      <div class="ms-auto d-flex align-items-center gap-3">
        <RuntimeStatus client:load />
        <div class="server-controls">
          <button id="btn-start"   class="btn btn-success btn-sm"><i class="fa fa-play me-1"></i>Start</button>
          <button id="btn-stop"    class="btn btn-danger btn-sm"><i class="fa fa-stop me-1"></i>Stop</button>
          <button id="btn-restart" class="btn btn-warning btn-sm"><i class="fa fa-rotate me-1"></i>Restart</button>
        </div>
      </div>
    </header>

    <!-- Views -->
    <main id="content">

      <!-- ── DASHBOARD ───────────────────────────────────────────── -->
      <div id="view-dashboard" class="view">

        <!-- Server Control Card -->
        <div class="card-panel server-control-card mb-4">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <!-- Status display -->
            <div class="d-flex align-items-center gap-3">
              <div id="dash-status-ring" class="status-ring offline">
                <i class="fa fa-server"></i>
              </div>
              <div>
                <div class="server-ctrl-title">Arma 3 Server</div>
                <div class="d-flex align-items-center gap-2 mt-1">
                  <span class="status-dot offline" id="dash-status-dot"></span>
                  <span id="dash-status-text" class="server-ctrl-status">Offline</span>
                  <span class="text-muted small" id="dash-pid-text"></span>
                </div>
              </div>
            </div>
            <!-- Big control buttons -->
            <div class="d-flex gap-2 flex-wrap">
              <button id="dash-btn-start" class="btn btn-ctrl btn-ctrl-start">
                <i class="fa fa-play"></i>
                <span>Start</span>
              </button>
              <button id="dash-btn-stop" class="btn btn-ctrl btn-ctrl-stop" disabled>
                <i class="fa fa-stop"></i>
                <span>Stop</span>
              </button>
              <button id="dash-btn-restart" class="btn btn-ctrl btn-ctrl-restart" disabled>
                <i class="fa fa-rotate"></i>
                <span>Restart</span>
              </button>
            </div>
          </div>
          <!-- Uptime / action feedback bar -->
          <div id="dash-action-bar" class="action-bar mt-3 d-none">
            <div class="action-bar-inner">
              <i class="fa fa-spinner fa-spin me-2"></i>
              <span id="dash-action-msg">Processing…</span>
            </div>
          </div>
        </div>

        <!-- Metric cards -->
        <div class="row g-4 mb-4">
          <div class="col-6 col-md-3">
            <div class="metric-card">
              <div class="metric-icon cpu"><i class="fa fa-microchip"></i></div>
              <div>
                <div class="metric-value" id="m-cpu">—</div>
                <div class="metric-label">CPU Usage</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="metric-card">
              <div class="metric-icon mem"><i class="fa fa-memory"></i></div>
              <div>
                <div class="metric-value" id="m-mem">—</div>
                <div class="metric-subvalue" id="m-mem-detail">—</div>
                <div class="metric-label">RAM Usage</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="metric-card">
              <div class="metric-icon disk"><i class="fa fa-hard-drive"></i></div>
              <div>
                <div class="metric-value" id="m-disk">—</div>
                <div class="metric-subvalue" id="m-disk-detail">—</div>
                <div class="metric-label">Server Data</div>
              </div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="metric-card">
              <div class="metric-icon temp"><i class="fa fa-temperature-half"></i></div>
              <div>
                <div class="metric-value" id="m-temp">—</div>
                <div class="metric-label">CPU Temp</div>
              </div>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-lg-8">
            <div class="card-panel">
              <div class="panel-header">
                <i class="fa fa-chart-line me-2"></i>Resource History
              </div>
              <canvas id="chart-metrics" height="120"></canvas>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="card-panel h-100">
              <div class="panel-header"><i class="fa fa-server me-2"></i>Server Info</div>
              <div class="info-list">
                <div class="info-row"><span>Status</span><span id="info-status" class="badge bg-danger">Offline</span></div>
                <div class="info-row"><span>PID</span><span id="info-pid">—</span></div>
                <div class="info-row"><span>Game Port</span><span id="info-port">—</span></div>
                <div class="info-row info-row-stack">
                  <span>Join Address</span>
                  <div class="join-address">
                    <code id="info-join-address">—</code>
                    <button id="btn-copy-join-address" class="btn btn-sm btn-outline-secondary btn-icon" title="Copy join address">
                      <i class="fa fa-copy"></i>
                    </button>
                  </div>
                </div>
                <div class="info-row"><span>Active Mods</span><span id="info-mods">—</span></div>
              </div>
              <hr class="divider" />
              <div class="panel-header"><i class="fa fa-wrench me-2"></i>Quick Actions</div>
              <div class="d-grid gap-2 mt-2">
                <button id="btn-install-server" class="btn btn-outline-primary btn-sm">
                  <i class="fa fa-download me-1"></i>Install / Update Server
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="card-panel mt-4">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-table-list me-2"></i>Session Metrics</span>
            <button id="btn-refresh-sessions" class="btn btn-sm btn-outline-secondary" title="Refresh sessions">
              <i class="fa fa-rotate"></i>
            </button>
          </div>
          <div class="small text-muted mt-1 mb-2">CPU and RAM usage recorded per game session. Download a session as CSV.</div>
          <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
              <thead>
                <tr>
                  <th>Started</th>
                  <th>Duration</th>
                  <th>Avg / Peak CPU</th>
                  <th>Cores</th>
                  <th>Avg / Peak RAM</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="sessions-table-body">
                <tr><td colspan="6" class="text-muted">Loading...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ── MODS ───────────────────────────────────────────────── -->
      <div id="view-mods" class="view d-none">

        <div id="steamcmd-panel" class="card-panel mb-3">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
              <div class="panel-header mb-1"><i class="fab fa-steam me-2"></i>SteamCMD Session</div>
              <div class="small text-muted">
                <span id="steamcmd-status-badge" class="badge bg-secondary me-2">Unknown</span>
                <span id="steamcmd-status-text">Checking SteamCMD status...</span>
              </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <button id="btn-open-steamcmd" class="btn btn-sm btn-outline-primary">
                <i class="fa fa-key me-1"></i>SteamCMD Login
              </button>
              <button class="btn btn-sm btn-outline-warning btn-reset-steamcmd">
                <i class="fa fa-broom me-1"></i>Reset SteamCMD
              </button>
            </div>
          </div>
        </div>

        <!-- Steam credential warning (shown when using anonymous login) -->
        <div id="steam-anon-warning" class="alert alert-warning d-flex gap-2 align-items-start mb-3 d-none">
          <i class="fa fa-triangle-exclamation mt-1 flex-shrink-0"></i>
          <div>
            <strong>SteamCMD login required.</strong>
            First-time installs need a Steam account and may ask for Steam Guard on your phone.
            Open SteamCMD Login, accept the verification, then retry the install.
          </div>
        </div>

        <div class="card-panel mb-3">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-layer-group me-2"></i>Creator DLCs</span>
            <div class="d-flex gap-2 flex-wrap">
              <button id="btn-download-cdlcs" class="btn btn-sm btn-outline-primary" title="Download Creator DLC server files with SteamCMD">
                <i class="fa fa-download me-1"></i>Download DLCs
              </button>
              <button id="btn-refresh-cdlcs" class="btn btn-sm btn-outline-secondary" title="Refresh Creator DLC status">
                <i class="fa fa-rotate"></i>
              </button>
            </div>
          </div>
          <div id="creator-dlc-container" class="mt-3">
            <div class="text-muted py-2">Loading...</div>
          </div>
        </div>

        <div class="card-panel mb-3">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-list-ul me-2"></i>Modlists</span>
            <button id="btn-refresh-modlists" class="btn btn-sm btn-outline-secondary">
              <i class="fa fa-rotate"></i>
            </button>
          </div>
          <div id="modlist-container" class="mt-2">
            <div class="text-muted py-2">Loading...</div>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <div class="card-panel">
              <div class="panel-header"><i class="fa fa-plus-circle me-2"></i>Install Mod by Workshop ID</div>
              <div class="input-group mt-2">
                <input type="text" id="mod-id-input" class="form-control" placeholder="e.g. 463939057" />
                <button id="btn-install-mod" class="btn btn-primary">
                  <i class="fa fa-download me-1"></i>Install
                </button>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card-panel">
              <div class="panel-header"><i class="fa fa-file-import me-2"></i>Import HTML Preset</div>
              <div class="mt-2">
                <input type="file" id="preset-file" class="form-control" accept=".html" />
                <button id="btn-load-preset" class="btn btn-secondary mt-2 w-100">
                  <i class="fa fa-upload me-1"></i>Load Preset
                </button>
                <div class="input-group mt-3">
                  <select id="saved-preset-select" class="form-select">
                    <option value="">Saved presets on server</option>
                  </select>
                  <button id="btn-load-saved-preset" class="btn btn-outline-primary" title="Load selected server preset">
                    <i class="fa fa-folder-open me-1"></i>Load
                  </button>
                  <button id="btn-delete-saved-preset" class="btn btn-outline-danger" title="Delete selected server preset">
                    <i class="fa fa-trash"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Preset preview modal -->
        <div id="preset-preview" class="card-panel d-none mb-3">
          <div class="panel-header"><i class="fa fa-list-check me-2"></i>Mods in Preset <span id="preset-name"></span></div>
          <p class="text-muted small mt-2">Select mods to install:</p>
          <div class="input-group mb-3">
            <input id="preset-save-name" class="form-control" placeholder="Modlist name" />
            <button id="btn-save-modlist" class="btn btn-outline-primary">
              <i class="fa fa-floppy-disk me-1"></i>Save Modlist
            </button>
          </div>
          <div id="preset-mod-list"></div>
          <div class="mt-3 d-flex gap-2">
            <button id="btn-preset-select-all" class="btn btn-sm btn-outline-secondary">Select All</button>
            <button id="btn-install-preset" class="btn btn-sm btn-success">
              <i class="fa fa-download me-1"></i>Install Missing
            </button>
          </div>
        </div>

        <!-- Install progress -->
        <div id="install-progress" class="card-panel d-none mb-3">
          <div class="panel-header"><i class="fa fa-spinner fa-spin me-2"></i>Installing…</div>
          <pre id="install-log" class="log-box mt-2"></pre>
        </div>

        <!-- Mod list -->
        <div class="card-panel">
          <div class="panel-header d-flex justify-content-between">
            <span><i class="fa fa-puzzle-piece me-2"></i>Installed Mods</span>
            <button id="btn-refresh-mods" class="btn btn-sm btn-outline-secondary">
              <i class="fa fa-rotate"></i>
            </button>
          </div>
          <div id="mod-list-container" class="mt-3">
            <div class="text-muted text-center py-4">Loading…</div>
          </div>
        </div>
      </div>

      <!-- ── FILE MANAGER ───────────────────────────────────────── -->
      <div id="view-files" class="view d-none">
        <div class="card-panel">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-folder-open me-2"></i>File Manager</span>
            <div class="d-flex gap-2">
              <button id="btn-refresh-files" class="btn btn-sm btn-outline-secondary" type="button" title="Sync this folder with disk">
                <i class="fa fa-rotate"></i>
              </button>
              <label class="btn btn-sm btn-outline-primary mb-0">
                <i class="fa fa-upload me-1"></i>Upload
                <input type="file" id="file-upload-input" class="d-none" multiple />
              </label>
            </div>
          </div>
          <nav id="breadcrumb" aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb mb-0" id="breadcrumb-list"></ol>
          </nav>
          <div id="file-drop-zone" class="file-drop-zone mt-3">
            <i class="fa fa-cloud-arrow-up"></i>
            <span>Drop files here to upload to the current folder</span>
          </div>
          <div id="file-list" class="mt-3"></div>
        </div>
        <!-- Inline editor -->
        <div id="file-editor-panel" class="card-panel mt-3 d-none">
          <div class="panel-header d-flex justify-content-between">
            <span id="editor-filename"></span>
            <button id="btn-save-file" class="btn btn-sm btn-success">
              <i class="fa fa-floppy-disk me-1"></i>Save
            </button>
          </div>
          <div id="file-editor" class="syntax-editor-host mt-2"></div>
        </div>
      </div>

      <!-- ── CONFIG EDITOR ──────────────────────────────────────── -->
      <div id="view-config" class="view d-none">
        <div class="card-panel mb-3">
          <div class="panel-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><i class="fa fa-terminal me-2"></i>Startup Command</span>
            <button id="btn-copy-startup-command" class="btn btn-sm btn-outline-primary">
              <i class="fa fa-copy me-1"></i>Copy
            </button>
          </div>
          <pre id="startup-command" class="log-box mt-2"></pre>
        </div>

        <div class="card-panel mb-3">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-power-off me-2"></i>Startup Settings</span>
            <button id="btn-save-startup" class="btn btn-sm btn-success">
              <i class="fa fa-floppy-disk me-1"></i>Save Startup
            </button>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-md-4"><label class="form-label">Server Binary</label><select id="startup-binary" class="form-select"><option value="arma3server_x64">arma3server_x64</option></select></div>
            <div class="col-md-4"><label class="form-label">Bind IP <span class="text-muted small" title="Leave as 0.0.0.0 to bind to all interfaces (recommended). Set your actual public IP only if needed for specific routing.">ⓘ</span></label><input id="startup-ip" class="form-control" placeholder="0.0.0.0 (recommended)" /></div>
            <div class="col-md-4"><label class="form-label">Game Port</label><input id="startup-port" class="form-control" type="number" min="1" max="65535" /></div>
            <div class="col-md-6"><label class="form-label">Profiles Directory</label><input id="startup-profiles" class="form-control" /></div>
            <div class="col-md-3"><label class="form-label">Max Players</label><input id="startup-max-players" class="form-control" type="number" min="1" max="256" /></div>
            <div class="col-md-3"><label class="form-label">Server Password</label><input id="startup-password" class="form-control" /></div>
            <div class="col-md-6">
              <label class="form-label">Startup Mission</label>
              <div class="input-group">
                <select id="startup-mission" class="form-select"><option value="">Select a mission from mpmissions</option></select>
                <button id="btn-refresh-missions" class="btn btn-outline-secondary" type="button" title="Refresh missions"><i class="fa fa-rotate"></i></button>
                <button id="btn-apply-mission" class="btn btn-primary" type="button"><i class="fa fa-check me-1"></i>Apply</button>
              </div>
            </div>
            <div class="col-12"><label class="form-label">Extra Startup Parameters</label><input id="startup-extra" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">Server-Side Only Mods</label><input id="startup-server-mods" class="form-control" placeholder="@servermod;@another;" /></div>
            <div class="col-md-6"><label class="form-label">Optional Client-Side Mods</label><input id="startup-optional-mods" class="form-control" placeholder="@optional1;@optional2;" /></div>
            <div class="col-md-4"><label class="form-label">Extra Ports</label><input id="startup-extra-ports" class="form-control" placeholder="2303,2304,2305,2306" /></div>
            <div class="col-md-5 hc-setting">
              <label class="form-label" for="startup-headless">Headless Clients <span class="hc-advanced-tag">Advanced</span></label>
              <input id="startup-headless" class="form-control" type="number" min="0" max="5" value="0" aria-describedby="startup-headless-help startup-headless-warning startup-headless-status" />
              <div id="startup-headless-help" class="hc-help">0 disables HC. Requires a prepared mission; each HC occupies one player slot.</div>
              <div id="startup-headless-warning" class="hc-readiness-warning d-none" role="status">
                <i class="fa fa-triangle-exclamation" aria-hidden="true"></i>
                The manager starts the processes, but the mission must provide HC slots and AI-transfer scripts.
              </div>
              <div id="startup-headless-status" class="hc-process-status is-idle" aria-live="polite">HC disabled</div>
            </div>
            <div class="col-md-3"><label class="form-label">SteamCMD Flags</label><input id="startup-steam-flags" class="form-control" /></div>
            <div class="col-12 d-flex flex-wrap gap-3">
              <label class="form-check form-switch"><input id="startup-auto-update" class="form-check-input" type="checkbox" /> <span class="form-check-label">Automatic Updates</span></label>
              <label class="form-check form-switch"><input id="startup-lowercase" class="form-check-input" type="checkbox" /> <span class="form-check-label">Repair Lowercase Mods</span></label>
              <label class="form-check form-switch"><input id="startup-validate" class="form-check-input" type="checkbox" /> <span class="form-check-label">Validate Server Files</span></label>
              <label class="form-check form-switch"><input id="startup-disable-battleye" class="form-check-input" type="checkbox" /> <span class="form-check-label">Disable BattlEye</span></label>
            </div>
          </div>
        </div>

        <div class="card-panel">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-sliders me-2"></i>Config Editor</span>
            <button id="btn-save-config" class="btn btn-sm btn-success">
              <i class="fa fa-floppy-disk me-1"></i>Save
            </button>
          </div>
          <ul class="nav nav-tabs mt-3" id="config-tabs">
            <li class="nav-item"><a class="nav-link active" href="#" data-config="server.cfg">server.cfg</a></li>
            <li class="nav-item"><a class="nav-link" href="#" data-config="basic.cfg">basic.cfg</a></li>
          </ul>
          <div id="config-editor" class="syntax-editor-host mt-3"></div>
        </div>
      </div>

      <!-- ── LOGS ───────────────────────────────────────────────── -->
      <div id="view-logs" class="view d-none">
        <div class="log-workspace-header">
          <div>
            <div class="log-workspace-kicker">OPERATIONS / TELEMETRY</div>
            <h2 class="log-workspace-title">Server Logs</h2>
            <p class="log-workspace-subtitle">Live output, player access decisions, and server-run history in one place.</p>
          </div>
          <span id="player-tracking-status" class="tracking-chip tracking-partial"><i class="fa fa-circle-nodes"></i> Partial tracking</span>
        </div>

        <div class="log-workspace-tabs" role="tablist" aria-label="Server log views">
          <button id="log-tab-live" class="active" type="button" role="tab" aria-selected="true" aria-controls="log-panel-live" tabindex="0" data-log-panel="live">
            <span class="log-tab-icon"><i class="fa fa-wave-square"></i></span><span class="log-tab-copy"><strong>Live Console</strong><small>Streaming</small></span>
          </button>
          <button id="log-tab-players" type="button" role="tab" aria-selected="false" aria-controls="log-panel-players" tabindex="-1" data-log-panel="players">
            <span class="log-tab-icon"><i class="fa fa-user-shield"></i></span><span class="log-tab-copy"><strong>Player Activity</strong><small>Access</small></span>
          </button>
          <button id="log-tab-sessions" type="button" role="tab" aria-selected="false" aria-controls="log-panel-sessions" tabindex="-1" data-log-panel="sessions">
            <span class="log-tab-icon"><i class="fa fa-clock-rotate-left"></i></span><span class="log-tab-copy"><strong>Sessions</strong><small>History</small></span>
          </button>
        </div>

        <section id="log-panel-live" class="log-workspace-panel" role="tabpanel" aria-labelledby="log-tab-live" tabindex="0" data-log-panel-content="live">
          <div class="card-panel">
            <div class="panel-header d-flex justify-content-between align-items-center flex-wrap gap-2">
              <span class="d-flex align-items-center gap-2">
                <span><i class="fa fa-terminal me-2"></i>Live output</span>
                <span id="log-stream-status" class="badge text-bg-secondary">Connecting</span>
              </span>
              <div class="d-flex align-items-center flex-wrap gap-2">
                <span id="log-buffer-status" class="log-buffer-status">0 / 5,000 retained</span>
                <button id="log-new-lines" type="button" class="log-new-lines d-none">
                  <span id="log-new-lines-count">0</span> new · Jump to live
                </button>
                <label class="form-check form-switch mb-0 align-items-center d-flex gap-2">
                  <input class="form-check-input" type="checkbox" id="log-autoscroll" checked />
                  <span class="form-check-label small">Auto-scroll</span>
                </label>
                <button id="btn-clear-logs" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
              </div>
            </div>
            <div id="log-stream-notice" class="log-stream-notice d-none" role="status" aria-live="polite"></div>
            <div id="log-output" class="log-box log-workspace-console log-viewport mt-2" role="log" aria-label="Live server log" aria-live="off" tabindex="0">
              <div id="log-virtual-spacer" class="log-virtual-spacer"><div id="log-virtual-rows" class="log-virtual-rows"></div></div>
            </div>
          </div>
        </section>

        <section id="log-panel-players" class="log-workspace-panel d-none" role="tabpanel" aria-labelledby="log-tab-players" tabindex="0" hidden data-log-panel-content="players">
          <div class="card-panel">
            <div class="activity-toolbar">
              <div class="activity-field activity-session-field"><label for="player-session-select">Session</label><select id="player-session-select" class="form-select form-select-sm"></select></div>
              <div class="activity-field activity-search-field"><label for="player-search">Search</label><div class="input-group input-group-sm"><span class="input-group-text"><i class="fa fa-magnifying-glass"></i></span><input id="player-search" class="form-control" placeholder="Name, IP, Steam UID, GUID, reason" /></div></div>
              <div class="activity-field"><label for="player-outcome-filter">Outcome</label><select id="player-outcome-filter" class="form-select form-select-sm"><option value="">All outcomes</option><option value="successful">Successful</option><option value="rejected">Rejected</option><option value="removed">Removed</option><option value="pending">Pending</option><option value="unknown">Unknown</option></select></div>
              <div class="activity-field"><label for="player-reason-filter">Reason</label><select id="player-reason-filter" class="form-select form-select-sm"><option value="">All reasons</option><option value="missing_addon">Missing addon</option><option value="unsigned_data">Unsigned data</option><option value="battleye">BattlEye</option><option value="steam_check">Steam check</option><option value="network_timeout">Network timeout</option><option value="manual_kick">Manual kick</option><option value="banned">Banned</option><option value="unknown">Unknown</option></select></div>
              <button id="btn-refresh-player-activity" class="btn btn-sm btn-outline-secondary activity-refresh" title="Refresh"><i class="fa fa-rotate"></i></button>
            </div>

            <div class="activity-stats" aria-live="polite">
              <div class="activity-stat stat-success"><span>Successful</span><strong id="player-stat-success">0</strong></div>
              <div class="activity-stat stat-rejected"><span>Rejected</span><strong id="player-stat-rejected">0</strong></div>
              <div class="activity-stat stat-removed"><span>Removed</span><strong id="player-stat-removed">0</strong></div>
              <div class="activity-stat"><span>Unique players</span><strong id="player-stat-unique">0</strong></div>
            </div>

            <div class="table-responsive activity-table-wrap">
              <table class="table table-sm align-middle activity-table mb-0">
                <thead><tr><th>Time</th><th>Player</th><th>Identity</th><th>Outcome</th><th>Reason</th><th></th></tr></thead>
                <tbody id="player-activity-body"><tr><td colspan="6" class="text-muted">Select a session to inspect player activity.</td></tr></tbody>
              </table>
            </div>
            <button id="btn-load-more-players" class="btn btn-sm btn-outline-secondary d-none mt-3">Load more</button>
          </div>
        </section>

        <section id="log-panel-sessions" class="log-workspace-panel d-none" role="tabpanel" aria-labelledby="log-tab-sessions" tabindex="0" hidden data-log-panel-content="sessions">
          <div class="card-panel">
            <div class="panel-header d-flex justify-content-between align-items-center"><span><i class="fa fa-clock-rotate-left me-2"></i>Server run history</span><button id="btn-refresh-log-sessions" class="btn btn-sm btn-outline-secondary"><i class="fa fa-rotate"></i></button></div>
            <div class="table-responsive">
              <table class="table table-sm align-middle activity-table mb-0">
                <thead><tr><th>Started</th><th>Duration</th><th>Status</th><th>Players</th><th>Successful</th><th>Rejected</th><th>Removed</th><th></th></tr></thead>
                <tbody id="log-sessions-body"><tr><td colspan="8" class="text-muted">Loading sessions…</td></tr></tbody>
              </table>
            </div>
            <button id="btn-load-more-sessions" class="btn btn-sm btn-outline-secondary d-none mt-3">Load more</button>
          </div>
        </section>
      </div>

      <div class="modal fade" id="player-detail-modal" tabindex="-1" aria-labelledby="player-detail-title" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content player-detail-modal"><div class="modal-header"><div><div class="log-workspace-kicker">CONNECTION EVIDENCE</div><h5 id="player-detail-title" class="modal-title">Player activity</h5></div><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div id="player-detail-body" class="modal-body"></div></div></div>
      </div>

      <!-- ── RCON ───────────────────────────────────────────────── -->
      <div id="view-rcon" class="view d-none">
        <div class="card-panel">
          <div class="panel-header d-flex justify-content-between align-items-center">
            <span><i class="fa fa-satellite-dish me-2"></i>RCON Console</span>
            <button id="btn-rcon-refresh-players" class="btn btn-sm btn-outline-secondary">
              <i class="fa fa-rotate me-1"></i>Refresh players
            </button>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-12 d-flex gap-2">
              <input id="rcon-command-input" class="form-control" placeholder="say -1 Hello everyone" autocomplete="off" />
              <button id="btn-rcon-send" class="btn btn-primary text-nowrap"><i class="fa fa-paper-plane me-1"></i>Send</button>
            </div>
            <div class="col-12">
              <pre id="rcon-output" class="log-box"></pre>
            </div>
            <div class="col-12">
              <table class="table table-sm" id="rcon-players-table">
                <thead>
                  <tr><th>#</th><th>Name</th><th>IP</th><th>Ping</th><th>GUID</th><th></th></tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div id="view-settings" class="view d-none">
        <div class="row g-3">
          <div class="col-lg-6">
            <div class="card-panel">
              <div class="panel-header"><i class="fa fa-user-gear me-2"></i>Panel Account</div>
              <div class="row g-3 mt-1">
                <div class="col-12">
                  <label class="form-label">Username</label>
                  <input id="settings-username" class="form-control" autocomplete="username" />
                </div>
                <div class="col-12">
                  <label class="form-label">Current password</label>
                  <input id="settings-current-password" class="form-control" type="password" autocomplete="current-password" />
                </div>
                <div class="col-12">
                  <label class="form-label">New password</label>
                  <input id="settings-new-password" class="form-control" type="password" autocomplete="new-password" />
                </div>
                <div class="col-12">
                  <button id="btn-save-account" class="btn btn-primary">
                    <i class="fa fa-floppy-disk me-1"></i>Save Account
                  </button>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="card-panel mb-3">
              <div class="panel-header"><i class="fab fa-steam me-2"></i>Steam Login Link</div>
              <div class="small text-muted mt-2" id="settings-steam-status">Checking...</div>
              <a href="/auth/steam" id="btn-link-steam" class="btn btn-outline-primary mt-3">
                <i class="fab fa-steam me-1"></i>Link Steam Session
              </a>
            </div>
            <div class="card-panel">
              <div class="panel-header"><i class="fa fa-rotate-left me-2"></i>SteamCMD Factory Setup</div>
              <div class="small text-muted mt-2">Clears SteamCMD login cache and runs SteamCMD once, leaving it ready for first login and Steam Guard verification.</div>
              <button class="btn btn-outline-warning mt-3 btn-reset-steamcmd">
                <i class="fa fa-broom me-1"></i>Reset SteamCMD
              </button>
            </div>
          </div>
          <div class="col-12">
            <div class="card-panel">
              <div class="panel-header"><i class="fa fa-rotate-right me-2"></i>Panel Container</div>
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2">
                <div>
                  <div class="fw-semibold">Restart the manager container</div>
                  <div class="small text-muted">Restarts the panel process only. Mods, config, and server files are untouched. The game server must be stopped first.</div>
                </div>
                <button id="btn-open-restart-app" class="btn btn-outline-warning">
                  <i class="fa fa-rotate-right me-1"></i>Restart Panel
                </button>
              </div>
            </div>
          </div>
          <div class="col-12">
            <div class="card-panel danger-zone">
              <div class="panel-header text-danger"><i class="fa fa-triangle-exclamation me-2"></i>Danger Zone</div>
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2">
                <div>
                  <div class="fw-semibold">Factory reset all persistent data</div>
                  <div class="small text-muted">Server files, mods, SQLite state, Steam credentials and session keys will be erased.</div>
                </div>
                <button id="btn-open-factory-reset" class="btn btn-danger">
                  <i class="fa fa-power-off me-1"></i>Factory Reset
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- SteamCMD Login Modal -->
<div class="modal fade" id="steamcmd-modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content modal-dark">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fab fa-steam me-2"></i>SteamCMD Login</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-md-5">
            <label class="form-label">Steam username</label>
            <input id="steamcmd-user" class="form-control" autocomplete="username" />
          </div>
          <div class="col-md-5">
            <label class="form-label">Steam password</label>
            <input id="steamcmd-pass" class="form-control" type="password" autocomplete="current-password" />
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <button id="btn-steamcmd-start" class="btn btn-primary w-100">
              <i class="fa fa-play me-1"></i>Start
            </button>
          </div>
        </div>

        <div id="steamcmd-input-panel" class="steamcmd-input-panel d-none mt-3">
          <label class="form-label">Steam Guard / SteamCMD input</label>
          <div class="input-group">
            <input id="steamcmd-code" class="form-control" autocomplete="one-time-code" />
            <button id="btn-steamcmd-send" class="btn btn-success">
              <i class="fa fa-paper-plane me-1"></i>Send
            </button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
          <div class="small text-muted" id="steamcmd-modal-state">Idle</div>
          <button id="btn-steamcmd-cancel" class="btn btn-sm btn-outline-danger">
            <i class="fa fa-stop me-1"></i>Cancel
          </button>
        </div>
        <pre id="steamcmd-log" class="log-box mt-2"></pre>
      </div>
    </div>
  </div>
</div>

<!-- Factory Reset Modal -->
<div class="modal fade" id="factory-reset-modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content modal-dark factory-reset-modal">
      <div class="modal-header">
        <h5 class="modal-title text-danger"><i class="fa fa-triangle-exclamation me-2"></i>Factory Reset</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="factory-reset-form">
          <div class="alert alert-danger py-2">This permanently erases every persistent Arma 3 Manager volume. This action cannot be undone.</div>
          <label class="form-label" for="factory-reset-password">Current panel password</label>
          <input id="factory-reset-password" class="form-control mb-3" type="password" autocomplete="current-password" />
          <label class="form-label" for="factory-reset-confirmation">Type <code>RESET ALL ARMA3 DATA</code></label>
          <input id="factory-reset-confirmation" class="form-control" autocomplete="off" spellcheck="false" />
        </div>
        <div id="factory-reset-progress" class="d-none py-4 text-center">
          <i class="fa fa-spinner fa-spin fa-2x text-danger mb-3"></i>
          <div class="fw-semibold">Resetting persistent storage</div>
          <div class="small text-muted mt-1">Waiting for the clean API instance...</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button id="btn-confirm-factory-reset" type="button" class="btn btn-danger" disabled>
          <i class="fa fa-trash-can me-1"></i>Erase Everything
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Restart Panel Modal -->
<div class="modal fade" id="restart-app-modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content modal-dark">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fa fa-rotate-right me-2"></i>Restart Panel</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="restart-app-form">
          <div class="alert alert-warning py-2">Restarts the manager container only. No files, mods, or configuration are deleted.</div>
          <label class="form-label" for="restart-app-password">Current panel password</label>
          <input id="restart-app-password" class="form-control" type="password" autocomplete="current-password" />
        </div>
        <div id="restart-app-progress" class="d-none py-4 text-center">
          <i class="fa fa-spinner fa-spin fa-2x text-warning mb-3"></i>
          <div class="fw-semibold">Restarting panel</div>
          <div class="small text-muted mt-1">Waiting for the panel to come back up...</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button id="btn-confirm-restart-app" type="button" class="btn btn-warning">
          <i class="fa fa-rotate-right me-1"></i>Restart
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Toast container -->
<div id="toast-container" class="position-fixed bottom-0 end-0 p-3" style="z-index:9999"></div>
</BaseLayout>
