---
import 'bootstrap/dist/css/bootstrap.min.css';
import '@fortawesome/fontawesome-free/css/all.min.css';
import '../styles/astro.css';

interface Props { title: string }
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#18181b" />
    <meta name="description" content="Panel de control del servidor Arma 3 de Brigada 46" />
    <title>{title}</title>
    <link rel="preload" href="/assets/brigada_46.png" as="image" />
    <link rel="stylesheet" href="/css/style.css" />
    <script is:inline src="/config.js"></script>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/runtime.js';
    </script>
  </body>
</html>
