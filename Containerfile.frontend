FROM nginx:1.27-alpine

COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY web/public/ /usr/share/nginx/html/

EXPOSE 8080/tcp

CMD ["/bin/sh", "-c", "printf \"window.ARMA3_API_BASE = '%s';\\nwindow.ARMA3_REST_ONLY = %s;\\n\" \"${ARMA3_API_BASE:-}\" \"${ARMA3_REST_ONLY:-true}\" > /usr/share/nginx/html/config.js && nginx -g 'daemon off;'"]
