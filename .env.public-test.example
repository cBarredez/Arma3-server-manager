# Public connection test environment.
# Copy this file to .env.public-test and replace placeholders with your real network values.
# Do not commit .env.public-test because it may contain your real public IP.

# SteamCMD account
STEAM_USER=
STEAM_PASS=

# Web management panel
WEB_PORT=8080
WEB_USERNAME=admin
WEB_PASSWORD=change_this_panel_password
SESSION_SECRET=change_this_to_a_long_random_secret

# Keep the web panel private on the host.
WEB_BIND_IP=127.0.0.1
BASE_URL=http://127.0.0.1:8080

# Public game address shown in the dashboard as YOUR_PUBLIC_IP_OR_DOMAIN:2302.
# Same PC joins with 127.0.0.1:2302.
# LAN players join with YOUR_SERVER_LAN_IP:2302.
# Internet players join with YOUR_PUBLIC_IP_OR_DOMAIN:2302.
PUBLIC_JOIN_HOST=YOUR_PUBLIC_IP_OR_DOMAIN
FRONTEND_ORIGIN=
STEAM_OWNER_IDS=

# Arma 3 public test ports.
# Forward these UDP ports on your router/firewall to YOUR_SERVER_LAN_IP.
SERVER_PORT=2302
SERVER_QUERY_PORT=2303
BATTLEYE_PORT=2304
VON_PORT=2305

# Default Arma 3 server settings
SERVER_NAME=Arma 3 Public Test
SERVER_PASSWORD=
SERVER_PASSWORD_ADMIN=change_this_admin_password
SERVER_MAX_PLAYERS=40
AUTO_START_SERVER=false

# Optional comma-separated Creator DLC Steam app IDs for the Download DLCs action.
CREATOR_DLC_APP_IDS=

# Runtime
MOCK_STEAMCMD=false
TZ=America/Mexico_City
SERVER_MEM_LIMIT=14g

# Keep this blank unless you intentionally use the host-network overlay.
# On Windows this project usually uses native Podman port publishing instead.
#API_NETWORK_MODE=host
#API_PORT=8081
#ARMA3_API_BACKEND=10.89.0.1:8081
