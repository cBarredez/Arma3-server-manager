PROJECT_NAME           = "Arma 3 Server Manager Backend"
PROJECT_BRIEF          = "ASP.NET Core API for managing an Arma 3 dedicated server"
OUTPUT_DIRECTORY       = docs/generated/backend
INPUT                  = backend/Arma3Manager.Api docs/backend-mainpage.md
FILE_PATTERNS          = *.cs *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = docs/backend-mainpage.md
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
HAVE_DOT               = NO
QUIET                  = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
EXCLUDE_PATTERNS       = */bin/* */obj/*
